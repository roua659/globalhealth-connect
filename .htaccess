RewriteEngine On
RewriteBase /

# Ne pas réécrire si le fichier/dossier existe déjà dans public
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

# Rediriger la racine vers public/index.html par défaut
RewriteRule ^$ public/index.html [L]